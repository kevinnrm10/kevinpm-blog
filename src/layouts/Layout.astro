---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Product Manager especializado en IA y automatización. Reflexiones sobre producto, datos y tecnología.', image = '/og-image.png' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
    
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-gray-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-4xl mx-auto px-6 py-6 flex items-center justify-between">
        <a href={import.meta.env.BASE_URL} class="text-2xl font-bold tracking-tight hover:text-blue-600 transition-colors">
          Kevin<span class="text-blue-600">PM</span>
        </a>
        <div class="flex gap-8 items-center">
          <a href={import.meta.env.BASE_URL} class="text-gray-600 hover:text-gray-900 transition-colors font-medium">Blog</a>
          <a href={`${import.meta.env.BASE_URL}about`} class="text-gray-600 hover:text-gray-900 transition-colors font-medium">Sobre mí</a>
          <a href="https://www.linkedin.com/in/kevinriosmerino/" target="_blank" rel="noopener"
             class="text-blue-600 hover:text-blue-800 transition-colors font-medium">
            LinkedIn →
          </a>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 mt-20">
      <div class="max-w-4xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-gray-600 text-sm">
            © {new Date().getFullYear()} Kevin Ríos. Product Manager.
          </p>
          <div class="flex gap-6">
            <a href="https://www.linkedin.com/in/kevinriosmerino/" target="_blank" rel="noopener"
               class="text-gray-600 hover:text-blue-600 transition-colors text-sm">
              LinkedIn
            </a>
            <a href="https://github.com/kevinnrm10" target="_blank" rel="noopener"
               class="text-gray-600 hover:text-blue-600 transition-colors text-sm">
              GitHub
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
