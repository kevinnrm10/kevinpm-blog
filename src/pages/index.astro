---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Kevin PM - Product Manager & IA">
  <!-- Hero Section -->
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="space-y-6">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-tight">
        Product Manager.<br/>
        <span class="gradient-text">IA & Automatización.</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 max-w-2xl leading-relaxed">
        Reflexiones sobre producto, datos y tecnología desde Barcelona.
      </p>
      <div class="flex gap-4 items-center pt-4">
        <a 
          href="https://www.linkedin.com/in/kevinriosmerino/"
          target="_blank" 
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors"
        >
          Conecta en LinkedIn
        </a>
        <a 
          href="#posts" 
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-gray-900 text-gray-900 rounded-lg font-medium hover:bg-gray-900 hover:text-white transition-colors"
        >
          Ver artículos ↓
        </a>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section id="posts" class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold mb-12">Últimos artículos</h2>
    
    <div class="space-y-12">
      {posts.map((post) => {
        const formattedDate = new Intl.DateTimeFormat('es-ES', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        }).format(post.data.pubDate);

        return (
          <article class="group">
            <a href={`/blog/${post.slug}/`} class="block">
              <div class="space-y-3">
                <div class="flex items-center gap-3 text-sm text-gray-600">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formattedDate}
                  </time>
                  {post.data.readingTime && (
                    <>
                      <span>·</span>
                      <span>{post.data.readingTime} lectura</span>
                    </>
                  )}
                </div>
                
                <h3 class="text-2xl md:text-3xl font-bold tracking-tight group-hover:text-blue-600 transition-colors">
                  {post.data.title}
                </h3>
                
                <p class="text-lg text-gray-600 leading-relaxed">
                  {post.data.description}
                </p>

                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 pt-2">
                    {post.data.tags.map((tag) => (
                      <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        );
      })}
    </div>
  </section>

  <!-- Newsletter CTA (optional - puedes activarlo cuando tengas newsletter) -->
  <!-- <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-12 text-white text-center">
      <h2 class="text-3xl font-bold mb-4">Recibe los nuevos artículos</h2>
      <p class="text-xl mb-8 text-blue-50">
        Un email semanal con reflexiones sobre producto, IA y automatización.
      </p>
      <form class="max-w-md mx-auto flex gap-3">
        <input 
          type="email" 
          placeholder="tu@email.com" 
          class="flex-1 px-4 py-3 rounded-lg text-gray-900"
          required
        />
        <button 
          type="submit" 
          class="px-6 py-3 bg-white text-blue-600 rounded-lg font-medium hover:bg-gray-100 transition-colors"
        >
          Suscribirse
        </button>
      </form>
    </div>
  </section> -->
</Layout>
